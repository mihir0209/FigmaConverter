# FigmaConverter Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# Figma API (required)
# ============================================================
# Get your token: https://www.figma.com/developers/api#access-tokens
#
# IMPORTANT: Your Figma seat type affects rate limits:
#   View/Collab seat: 6 requests/month (not enough for this tool)
#   Dev/Full seat:    10-20 requests/minute (works great)
#
# On the FREE Starter plan, you can upgrade to a Dev/Full seat at no cost.
# Check your seat: Figma → Settings → Account → Seat type
FIGMA_API_TOKEN=

# ============================================================
# OpenCode Runtime Connection
# ============================================================
# opencode serve is started automatically on port 4096.
# Override if you run it manually or on a different host/port.
OPENCODE_HOST=127.0.0.1
OPENCODE_PORT=4096
# OPENCODE_PROVIDER_ID=    # Force a specific provider (e.g. "anthropic")
# OPENCODE_MODEL_ID=       # Force a specific model (e.g. "claude-sonnet-4-6")

# ============================================================
# Server Configuration
# ============================================================
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000

# ============================================================
# AI Cache (optional)
# ============================================================
AI_CACHE_ENABLED=false
AI_CACHE_TTL_DAYS=7

# ============================================================
# MCP Server (optional)
# ============================================================
# FIGMA_MCP_ENABLED=true
# FIGMA_MCP_TRANSPORT=stdio
# FIGMA_MCP_PORT=3845
# FIGMA_MCP_HOST=127.0.0.1
# FIGMA_MCP_API_KEY=

# ============================================================
# Figma Processor Tuning
# ============================================================
# FIGMA_MAX_CONCURRENCY=5
# MAX_THREADS=3
# MAX_FRAMES_PER_JOB=50
# FIGMA_REQUEST_DELAY=0.5   # seconds between API calls (burst protection)
# FIGMA_CACHE_TTL=300       # seconds to cache API responses (default 5 min)

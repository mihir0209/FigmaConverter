# AI Engine Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# GPT4Free (RECOMMENDED - Truly Free, no API key needed)
# ============================================================
# Run g4f server: docker run -p 8080:8080 hlohaus789/g4f
G4F_ENDPOINT=http://localhost:8080/v1/chat/completions
G4F_MODELS_ENDPOINT=http://localhost:8080/v1/models

# ============================================================
# Free Tier Provider API Keys
# ============================================================

# Groq (Free: 30 RPM, 14,400 RPD)
# Sign up: https://console.groq.com
GROQ_API_KEY=

# OpenRouter (Free: 23 free models with :free suffix)
# Sign up: https://openrouter.ai
OPENROUTER_API_KEY=

# Google Gemini (Free: 5-30 RPM depending on model)
# Sign up: https://aistudio.google.com
GEMINI_API_KEY=

# NVIDIA NIM (Free: 40 RPM)
# Sign up: https://build.nvidia.com
NVIDIA_API_KEY=

# Cerebras (Free: 30 RPM, 14,400 RPD)
# Sign up: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Cloudflare Workers AI (Free: 10K neurons/day)
# Sign up: https://dash.cloudflare.com
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# GitHub Models (Free tier varies)
# Sign up: https://github.com/marketplace/models
GITHUB_API_KEY=

# Vercel AI Gateway (Free: $5/month)
# Sign up: https://vercel.com
VERCEL_API_KEY=

# Cohere (Free: 20 RPM, 1000 requests/month)
# Sign up: https://cohere.com
COHERE_API_KEY=

# Mistral (Free: 1 RPS, 500K tokens/min)
# Sign up: https://console.mistral.ai
MISTRAL_API_KEY=

# HuggingFace (Free: $0.10/month credits)
# Sign up: https://huggingface.co
HUGGINGFACE_API_KEY=

# LongCat (Free tier)
# Sign up: https://longcat.chat
LONGCAT_API_KEY=

# Z AI / BigModel - Free: glm-4.7-flash, glm-4.5-flash, glm-4.6v-flash (vision)
# Sign up: https://bigmodel.cn
ZAI_API_KEY=

# ============================================================
# Server Configuration
# ============================================================

# Admin API key for management endpoints (toggle, roll-key, change-model)
# Leave empty for development mode (no auth required)
ADMIN_API_KEY=

# CORS origins (comma-separated for multiple, * for all)
CORS_ORIGINS=*

# ============================================================
# CDN Config Sync (Optional)
# ============================================================

# Set to "default" to auto-fetch latest providers from GitHub via jsDelivr CDN
# Set to any raw URL to fetch from a custom source
# Leave empty to disable (use local config.py only)
CDN_CONFIG_URL=default

# Cache TTL in seconds (default: 86400 = 24 hours)
# Lower = more frequent checks, Higher = less network usage
CDN_CONFIG_TTL=86400

# Git branch for default jsDelivr URL (default: main)
CDN_CONFIG_BRANCH=main
